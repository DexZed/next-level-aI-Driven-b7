model User {
    id String @id @default(cuid())
    name String 
    email String @unique
    password_hash String
    role Role @default(CUSTOMER)
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt

    technician Technician?
    bookings Booking[]
    reviews Review[]
}

enum Role {
    ADMIN
    CUSTOMER
    TECHNICIAN
}